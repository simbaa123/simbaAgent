  "kbArticles": [
    {
      "articleId": "kb_7001",
      "title": "7天无理由退货（支持条件与例外）",
      "content": "自签收次日起7天内，商品不影响二次销售可申请无理由退货。以下情形不支持：定制类、已拆封影响二次销售、激活绑定类商品等。退货运费承担以商品页及活动规则为准。",
      "tags": ["退货", "无理由", "时效"],
      "updatedAt": "2026-02-20T10:00:00+08:00"
    },
    {
      "articleId": "kb_7002",
      "title": "物流异常处理SOP（滞留/丢失/退回）",
      "content": "若物流状态异常或轨迹48小时无更新：1）核对地址信息与联系方式；2）创建催派工单并联系承运商；3）如判定丢失，按订单金额或规则发起补发/退款。",
      "tags": ["物流", "SOP", "异常"],
      "updatedAt": "2026-03-01T09:30:00+08:00"
    },
    {
      "articleId": "kb_7003",
      "title": "破损/少件处理SOP（需提供凭证）",
      "content": "签收后发现破损或少件：请提供外包装面单、开箱视频/照片等凭证。确认责任后可选择补发、部分退款或补偿券。",
      "tags": ["破损", "少件", "SOP"],
      "updatedAt": "2026-03-10T14:10:00+08:00"
    }
  ],
